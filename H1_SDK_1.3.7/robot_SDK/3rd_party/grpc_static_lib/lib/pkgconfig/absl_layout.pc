prefix=/workspace/third_libs/ubt20_libs/grpc_static_lib
exec_prefix=${prefix}
libdir=/workspace/third_libs/ubt20_libs/grpc_static_lib/lib
includedir=/workspace/third_libs/ubt20_libs/grpc_static_lib/include

Name: absl_layout
Description: Abseil layout library
URL: https://abseil.io/
Version: 20220623
Requires: absl_config = 20220623, absl_core_headers = 20220623, absl_meta = 20220623, absl_strings = 20220623, absl_span = 20220623, absl_utility = 20220623
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX
