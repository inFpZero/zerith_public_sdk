Version: 20220623
Requires: absl_base = 20220623, absl_config = 20220623, absl_raw_logging_internal = 20220623, absl_synchronization = 20220623
Libs: -L${libdir}  -labsl_cordz_handle
Cflags: -I${includedir} -DNOMINMAX
