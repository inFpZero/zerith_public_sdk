prefix=/workspace/third_libs/ubt20_libs/grpc_static_lib
exec_prefix=${prefix}
libdir=/workspace/third_libs/ubt20_libs/grpc_static_lib/lib
includedir=/workspace/third_libs/ubt20_libs/grpc_static_lib/include

Name: absl_debugging_internal
Description: Abseil debugging_internal library
URL: https://abseil.io/
Version: 20220623
Requires: absl_core_headers = 20220623, absl_config = 20220623, absl_dynamic_annotations = 20220623, absl_errno_saver = 20220623, absl_raw_logging_internal = 20220623
Libs: -L${libdir}  -labsl_debugging_internal
Cflags: -I${includedir} -DNOMINMAX
