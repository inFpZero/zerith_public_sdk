prefix=/workspace/third_libs/ubt20_libs/grpc_static_lib
exec_prefix=${prefix}
libdir=/workspace/third_libs/ubt20_libs/grpc_static_lib/lib
includedir=/workspace/third_libs/ubt20_libs/grpc_static_lib/include

Name: absl_strings_internal
Description: Abseil strings_internal library
URL: https://abseil.io/
Version: 20220623
Requires: absl_config = 20220623, absl_core_headers = 20220623, absl_endian = 20220623, absl_raw_logging_internal = 20220623, absl_type_traits = 20220623
Libs: -L${libdir}  -labsl_strings_internal
Cflags: -I${includedir} -DNOMINMAX
