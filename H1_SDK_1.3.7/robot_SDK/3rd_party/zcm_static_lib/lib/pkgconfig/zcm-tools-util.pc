prefix=/home/robot/third_libs/zcm_static_lib
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
libdir64=${exec_prefix}/lib64
includedir=${prefix}/include
datarootdir=${prefix}/share
jardir=${datarootdir}/java

Name: zcm
Description: Zero Communications and Marshalling (ZCM) Tools Utils
Requires:
Version: 1.2.0
Libs: -L${libdir} -L${libdir64} -lzcm_tools_util
Cflags: -I${includedir}
