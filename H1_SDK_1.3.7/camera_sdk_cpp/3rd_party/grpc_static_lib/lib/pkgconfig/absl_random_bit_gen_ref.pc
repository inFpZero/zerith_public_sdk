prefix=/workspace/third_libs/ubt20_libs/grpc_static_lib
exec_prefix=${prefix}
libdir=/workspace/third_libs/ubt20_libs/grpc_static_lib/lib
includedir=/workspace/third_libs/ubt20_libs/grpc_static_lib/include

Name: absl_random_bit_gen_ref
Description: Abseil random_bit_gen_ref library
URL: https://abseil.io/
Version: 20220623
Requires: absl_core_headers = 20220623, absl_random_internal_distribution_caller = 20220623, absl_random_internal_fast_uniform_bits = 20220623, absl_type_traits = 20220623
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX
