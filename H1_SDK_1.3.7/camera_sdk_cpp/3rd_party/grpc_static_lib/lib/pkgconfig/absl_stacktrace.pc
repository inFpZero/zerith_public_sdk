prefix=/workspace/third_libs/ubt20_libs/grpc_static_lib
exec_prefix=${prefix}
libdir=/workspace/third_libs/ubt20_libs/grpc_static_lib/lib
includedir=/workspace/third_libs/ubt20_libs/grpc_static_lib/include

Name: absl_stacktrace
Description: Abseil stacktrace library
URL: https://abseil.io/
Version: 20220623
Requires: absl_debugging_internal = 20220623, absl_config = 20220623, absl_core_headers = 20220623
Libs: -L${libdir}  -labsl_stacktrace
Cflags: -I${includedir} -DNOMINMAX
