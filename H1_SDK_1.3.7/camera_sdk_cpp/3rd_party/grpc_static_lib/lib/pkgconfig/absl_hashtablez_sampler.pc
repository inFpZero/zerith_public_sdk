prefix=/workspace/third_libs/ubt20_libs/grpc_static_lib
exec_prefix=${prefix}
libdir=/workspace/third_libs/ubt20_libs/grpc_static_lib/lib
includedir=/workspace/third_libs/ubt20_libs/grpc_static_lib/include

Name: absl_hashtablez_sampler
Description: Abseil hashtablez_sampler library
URL: https://abseil.io/
Version: 20220623
Requires: absl_base = 20220623, absl_config = 20220623, absl_exponential_biased = 20220623, absl_sample_recorder = 20220623, absl_synchronization = 20220623
Libs: -L${libdir}  -labsl_hashtablez_sampler
Cflags: -I${includedir} -DNOMINMAX
