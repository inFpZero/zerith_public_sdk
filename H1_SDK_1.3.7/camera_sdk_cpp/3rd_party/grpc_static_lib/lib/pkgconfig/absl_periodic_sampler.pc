prefix=/workspace/third_libs/ubt20_libs/grpc_static_lib
exec_prefix=${prefix}
libdir=/workspace/third_libs/ubt20_libs/grpc_static_lib/lib
includedir=/workspace/third_libs/ubt20_libs/grpc_static_lib/include

Name: absl_periodic_sampler
Description: Abseil periodic_sampler library
URL: https://abseil.io/
Version: 20220623
Requires: absl_core_headers = 20220623, absl_exponential_biased = 20220623
Libs: -L${libdir}  -labsl_periodic_sampler
Cflags: -I${includedir} -DNOMINMAX
