prefix=/workspace/third_libs/ubt20_libs/grpc_static_lib
exec_prefix=${prefix}
libdir=/workspace/third_libs/ubt20_libs/grpc_static_lib/lib
includedir=/workspace/third_libs/ubt20_libs/grpc_static_lib/include

Name: absl_flags_reflection
Description: Abseil flags_reflection library
URL: https://abseil.io/
Version: 20220623
Requires: absl_config = 20220623, absl_flags_commandlineflag = 20220623, absl_flags_private_handle_accessor = 20220623, absl_flags_config = 20220623, absl_strings = 20220623, absl_synchronization = 20220623, absl_flat_hash_map = 20220623
Libs: -L${libdir}  -labsl_flags_reflection
Cflags: -I${includedir} -DNOMINMAX
